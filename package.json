{
  "name": "simulabra",
  "version": "0.0.5",
  "repository": "simulabra/simulabra",
  "type": "module",
  "exports": {
    ".": "./src/base.js",
    "./html": "./src/html.js",
    "./test": "./src/test.js",
    "./llm": "./src/llm.js",
    "./db": "./src/db.js",
    "./live": "./src/live.js",
    "./http": "./src/http.js",
    "./time": "./src/time.js",
    "./logs": "./src/logs.js",
    "./tools": "./src/tools.js",
    "./runner": "./src/runner.js"
  },
  "module": "./src/base.js",
  "scripts": {
    "watchtest": "watchexec -w . -e js -r -- bun run src/runner.js",
    "test": "bun run src/runner.js",
    "test-ui": "bun run src/runner.js tests/ui",
    "test-bin": "bun run src/runner.js tests/bin",
    "gen-exports": "bun run bin/gen-exports.js"
  },
  "devDependencies": {
    "playwright": "latest"
  }
}
